            "presentation",
            "doc",
            "whiteboard",
            "custom"
          ],
          "inferrable": true
        },
        {
          "name": "title",
          "type": "string",
          "required": false,
          "description": "Title for the new design.",
          "enum": null,
          "inferrable": true
