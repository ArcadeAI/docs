{
  "id": "Canva",
  "label": "Canva",
  "version": "0.1.0",
  "description": "Arcade tools designed for LLMs to interact with Canva \u2014 create designs, export PDFs, autofill brand templates, and manage assets.",
  "metadata": {
    "category": "productivity",
    "iconUrl": "https://design-system.arcade.dev/icons/canva.svg",
    "isBYOC": false,
    "isPro": false,
    "type": "arcade",
    "docsLink": "https://docs.arcade.dev/en/resources/integrations/productivity/canva",
    "isComingSoon": false,
    "isHidden": false
  },
  "auth": {
    "type": "oauth2",
    "providerId": "canva",
    "allScopes": [
      "asset:read",
      "asset:write",
      "brandtemplate:content:read",
      "brandtemplate:meta:read",
      "design:content:read",
      "design:content:write",
      "design:meta:read",
      "folder:read",
      "profile:read"
    ]
  },
