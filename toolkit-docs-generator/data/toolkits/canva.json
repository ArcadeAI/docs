      "qualifiedName": "Canva.CreateDesign",
      "fullyQualifiedName": "Canva.CreateDesign@0.1.0",
      "description": "Create a new Canva design. Supports presentation, doc, whiteboard, and custom dimensions.",
      "parameters": [
        {
          "name": "design_type",
          "type": "string",
          "required": false,
          "description": "Type: presentation, doc, whiteboard, or custom.",
