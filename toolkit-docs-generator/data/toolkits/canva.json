    {
      "name": "ExportDesign",
      "qualifiedName": "Canva.ExportDesign",
      "fullyQualifiedName": "Canva.ExportDesign@0.1.0",
      "description": "Start an async export of a Canva design to PDF, PNG, JPG, SVG, PPTX, MP4, or GIF. Poll GetExportStatus for the download URL.",
      "parameters": [
        {
          "name": "design_id",
          "type": "string",
          "required": true,
          "description": "The Canva design ID to export.",
          "enum": null,
          "inferrable": true
        },
        {
          "name": "export_format",
          "type": "string",
          "required": true,
          "description": "Export format: pdf, png, jpg, svg, pptx, mp4, or gif.",
          "enum": [
            "pdf",
            "png",
            "jpg",
            "svg",
            "pptx",
            "mp4",
            "gif"
          ],
          "inferrable": true
        },
        {
          "name": "quality",
          "type": "string",
          "required": false,
          "description": "Quality for jpg/png: regular or pro.",
          "enum": [
            "regular",
            "pro"
          ],
          "inferrable": true
        },
        {
          "name": "pages",
          "type": "array",
          "required": false,
          "description": "Specific page numbers to export (1-indexed). All pages if omitted.",
          "enum": null,
          "inferrable": true
        }
      ],
      "auth": {
        "type": "oauth2",
        "providerId": "canva",
        "scopes": [
          "design:content:read"
        ]
      },
      "secrets": [],
      "output": {
        "description": "Export job ID. Use GetExportStatus to poll for the download URL."
      },
      "documentationChunks": [],
      "codeExample": "result = client.tools.execute(tool_name=\"Canva.ExportDesign\", user_id=\"user@example.com\", input={\"design_id\": \"DAFxxxxx\", \"export_format\": \"pdf\"})"
    },
