        {
          "name": "width",
          "type": "integer",
          "required": false,
          "description": "Width in pixels (custom type only).",
          "enum": null,
          "inferrable": false
        },
        {
          "name": "height",
          "type": "integer",
          "required": false,
          "description": "Height in pixels (custom type only).",
          "enum": null,
          "inferrable": false
