    {
      "name": "ListDesigns",
      "qualifiedName": "Canva.ListDesigns",
      "fullyQualifiedName": "Canva.ListDesigns@0.1.0",
      "description": "List designs in your Canva account with optional search and filtering.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "required": false,
          "description": "Search query to filter by name.",
          "enum": null,
          "inferrable": true
        },
        {
          "name": "ownership",
          "type": "string",
          "required": false,
          "description": "Filter by ownership: owned, shared, or any.",
          "enum": [
            "owned",
            "shared",
            "any"
          ],
          "inferrable": true
        },
        {
          "name": "limit",
          "type": "integer",
          "required": false,
          "description": "Max results (default 20, max 100).",
          "enum": null,
          "inferrable": true
        }
      ],
      "auth": {
        "type": "oauth2",
        "providerId": "canva",
        "scopes": [
          "design:meta:read"
        ]
      },
      "secrets": [],
      "output": {
        "description": "List of Canva designs."
      },
      "documentationChunks": [],
      "codeExample": "result = client.tools.execute(tool_name=\"Canva.ListDesigns\", user_id=\"user@example.com\", input={\"query\": \"proposal\"})"
    },
